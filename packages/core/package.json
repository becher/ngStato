{
  "name": "@ngstato/core",
  "version": "0.4.0",
  "private": false,
  "description": "Stato — Zero-dependency state management engine",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "vitest": "^1.6.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/becher/ngStato.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/becher/ngStato#readme",
  "bugs": {
    "url": "https://github.com/becher/ngStato/issues"
  },
  "author": "becher",
  "keywords": [
    "state-management",
    "store",
    "signals",
    "framework-agnostic",
    "rxjs-alternative",
    "ngstato"
  ]
}
